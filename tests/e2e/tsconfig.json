{
	"compilerOptions": {
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"lib": ["ESNext"],
		"types": ["bun"],
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"baseUrl": "../..",
		"paths": {
			"@zyncbase/client": ["sdk/typescript/src/index.ts"]
		}
	},
	"include": ["src/**/*.ts"]
}
