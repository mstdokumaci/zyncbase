{
  "workspaces": [
    "sdk/*"
  ],
  "scripts": {
    "test:e2e": "bun test tests/e2e/src/e2e.test.ts",
    "specs:compress": "uv run python scripts/compress_specs.py",
    "test:tsan": "zig build test -Dsanitize=thread --summary all",
    "test:safe": "zig build test -Doptimize=ReleaseSafe --summary all",
    "test:fast": "zig build test -Doptimize=ReleaseFast --summary all",
    "test:slowest": "zig build test-slowest -Doptimize=ReleaseSafe --summary all",
    "lint": "zig fmt src && zlint --deny-warnings && zig build lint && zig build check --summary all"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@zyncbase/client": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "^1.3.11"
  }
}
